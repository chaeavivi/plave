# --- 데이터베이스 ---
# 개발용 SQLite (그대로 사용 가능). 배포 시 Postgres 등으로 교체 후
# prisma/schema.prisma 의 provider 도 함께 변경하세요.
DATABASE_URL="file:./dev.db"

# --- 네이버 쇼핑 검색 API (선택) ---
# https://developers.naver.com 에서 애플리케이션 등록 후 발급.
# 설정하면 상세 페이지에 "다른 곳 최저가" 섹션이 자동으로 켜집니다.
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# --- 쿠팡 파트너스 (선택, 수익 제휴 링크) ---
# 파트너스 가입/승인 후 발급되는 키. 설정하면 쿠팡 구매 링크가
# 제휴 딥링크로 자동 전환됩니다. (lib/affiliate.ts)
COUPANG_ACCESS_KEY=""
COUPANG_SECRET_KEY=""
